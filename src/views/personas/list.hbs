<div class="container">
    <div class="row mt-5">
        {{#if concesionario.clientes.length}}
        <div class="col-md-10 mx-auto">
            <table class="table text-center">
                <thead>
                    <tr class="table-dark">
                        <th>nombre</th>
                        <th>apellido</th>
                        <th>edad</th>
                        <th>email</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each concesionario.clientes}}
                    <tr>
                        <td>{{nombre}}</td>
                        <td>{{lastname}}</td>
                        <td>{{age}}</td>
                        <td>{{email}}</td>
                        <td>
                            <a href="/edit/{{id_cliente}}" class="btn btn-warning">Editar</a>
                            <a href="/delete/{{id_cliente}}" class="btn btn-danger">Eliminar</a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
                <tfoot>
                    <tr class="table-dark">
                        <td colspan="5">registro de personas</td>
                    </tr>
                </tfoot>
            </table>
        </div>
        {{else}}
        <div class="card text-center mx-auto" style="width: 350px;">
            <div class="card-header">
                <h3>debes crear una nueva persona</h3>
            </div>
            <div class="card-body">
                <a href="/add" class="btn btn-primary">Crear Persona</a>
            </div>
        </div>
        {{/if}}
    </div>
</div>


